      "utter_greet": [
        {
          "text": "Hi! I'm the ResolveX AIML student grievance assistant. I can help you register a complaint, check a complaint status, or point you to FAQs. How can I help?"
        }
      ],
      "utter_goodbye": [
        {
          "text": "Take care — if anything else comes up, open Raise Grievances again anytime."
        }
      ],
      "utter_ask_category": [
        {
          "text": "What is your complaint about? You can pick a type — academic, infrastructure, hostel, harassment, facilities, or other — or describe it in your own words (e.g. hostel food, mess problem)."
        }
      ],
      "utter_ask_description": [
        {
          "text": "Please describe your issue briefly."
        }
      ],
      "utter_complaint_submitted": [
        {
          "text": "Your complaint has been successfully registered. Please save your Complaint ID for tracking."
        }
      ],
      "utter_contact": [
        {
          "text": "For urgent help, email aiml-grievance@college.edu or visit the AIML department office."
        }
      ],
      "utter_default": [
        {
          "text": "Please complete the complaint process, or say 'register a complaint' to start. I can also help you check a Complaint ID (e.g. CMP1234)."
        }
      ],
      "utter_thank_you": [
        {
          "text": "You are welcome. I am happy to assist you."
        },
        {
          "text": "Happy to help. If needed, I can also register another complaint."
        }
      ],
      "utter_chitchat": [
        {
          "text": "I’m your grievance helper. Say you want to register a complaint, or give me a Complaint ID to check its status."
        },
        {
          "text": "I focus on student grievances here — I can start a new complaint for you or look up a complaint ID when you are ready."
        }
      ],
      "utter_discussion": [
        {
          "text": "Please describe your issue for discussion."
        }
      ],
      "utter_faq": [
        {
          "text": "Here are some frequently asked questions."
        }
      ],
      "utter_start_complaint": [
        {
          "text": "I’ll help you file a complaint. First, what area does it fall under, or what should we call it? (Types include academic, infrastructure, hostel, harassment, facilities, or other — or use your own words.)"
        }
      ],
      "utter_faculty_feedback": [
        {
          "text": "Please provide your feedback about faculty."
        }
      ]
    }
